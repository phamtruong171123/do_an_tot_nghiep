generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  AGENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum CustomerSegment {
  POTENTIAL // Khách hàng tiềm năng
  NEW // Khách mới đã phát sinh giao dịch đầu tiên
  ACTIVE // Khách đang sử dụng/dùng dịch vụ
  VIP // Khách VIP/quan trọng
  DROPPED // Đã rời bỏ / lâu không tương tác
  SPAM // Spam / blacklist
}

model User {
  id           Int        @id @default(autoincrement())
  username     String     @unique
  passwordHash String
  email        String?    @unique
  role         UserRole
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  fullName String?

  agentProfile          AgentProfile?
  // Quan hệ ngược: các ticket được assign cho user này
  ticketsAssigned       Ticket[]       @relation("TicketAssignee")
  // Ticket do user này tạo
  ticketsCreated        Ticket[]       @relation("TicketCreatedBy")
  // Các conversation được assign cho user này
  assignedConversations Conversation[] @relation("ConversationAssignee")
  // Các note trên ticket do user này tạo
  ticketNotes           TicketNote[]   @relation("TicketNoteAuthor")

  dealsOwned     Deal[]         @relation("DealOwner")
  dealActivities DealActivity[] @relation("DealActivityAuthor")
}

model AgentProfile {
  userId       Int       @id
  online       Boolean   @default(false)
  userLoad     Int       @default(0)
  lastOnlineAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([online])
  @@index([lastOnlineAt])
}

model Channel {
  id              String   @id @default(uuid())
  type            String   @default("FACEBOOK")
  pageId          String   @unique
  pageName        String?
  pageAccessToken String   @db.VarChar(1000)
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  conversations Conversation[]
}

model Customer {
  id         Int     @id @default(autoincrement())
  /// externalId = external user id (PSID của Facebook, sau này có thể là ZaloID, email...)
  externalId String? @db.VarChar(191)

  name      String?
  avatarUrl String? @db.VarChar(1000)
  note      String?

  // thông tin liên hệ
  phoneNumber String? @db.VarChar(50)
  email       String? @db.VarChar(50)
  address     String? @db.VarChar(300)

  segment CustomerSegment @default(POTENTIAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Quan hệ: mỗi customer tối đa 01 conversation
  conversation Conversation?
  // 0..n ticket
  tickets      Ticket[]
  deals        Deal[]

  @@unique([externalId])
}

model Conversation {
  id              String    @id @default(uuid())
  channelId       String
  externalUserId  String
  title           String?
  lastMessageAt   DateTime?
  lastMessageText String?   @db.VarChar(1000)
  avataUrl        String?   @db.VarChar(1000)

  unreadCount Int @default(0)

  assigneeId Int?
  assignedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channel  Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  messages Message[]

  assignee User? @relation("ConversationAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  // Link 0..1 với Customer
  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])

  tickets Ticket[]

  @@unique([channelId, externalUserId])
  @@unique([customerId])
  @@index([updatedAt])
  @@index([assigneeId])
}

enum MessageSenderType {
  CUSTOMER
  AGENT
  BOT
}

model Message {
  id                String   @id @default(uuid())
  conversationId    String
  direction         String // "IN" | "OUT"
  text              String?  @db.Text
  externalMessageId String?  @unique
  status            String   @default("sent")
  createdAt         DateTime @default(now())

  sentBy       MessageSenderType @default(CUSTOMER)
  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  PENDING
  CLOSED
}

model Ticket {
  id          String  @id @default(cuid())
  code        String  @unique
  subject     String
  description String?

  status   TicketStatus   @default(OPEN)
  priority TicketPriority @default(NORMAL)

  dueAt      DateTime?
  resolvedAt DateTime?
  closedAt   DateTime?

  // Link với Conversation (nếu ticket sinh từ Chat)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])

  // Link với Customer 
  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])

  assigneeId Int?
  assignee   User? @relation("TicketAssignee", fields: [assigneeId], references: [id])

  createdById Int
  createdBy   User @relation("TicketCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Note của ticket
  notes TicketNote[]

  @@index([status])
  @@index([priority])
  @@index([assigneeId])
  @@index([dueAt])
  @@index([customerId])
}

model TicketNote {
  id         String   @id @default(cuid())
  ticketId   String
  authorId   Int
  content    String   @db.Text
  isInternal Boolean  @default(true)
  createdAt  DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation("TicketNoteAuthor", fields: [authorId], references: [id])

  @@index([ticketId])
  @@index([authorId])
}

model Faq {
  id Int @id @default(autoincrement())

  /// Câu hỏi chuẩn (FAQ Question)
  question String @db.VarChar(1000)

  /// Câu trả lời chuẩn (FAQ Answer)
  answer String @db.Text

  /// Tag chủ đề, ví dụ: ["chinh_sach", "doi_tra"]
  /// Dùng Json cho linh hoạt
  tags Json?

  /// Ngôn ngữ, ví dụ: "vi", "en"
  language String @default("vi")

  /// Bật / tắt FAQ (chỉ FAQ active mới dùng cho AI)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([language])
}

enum DealStage {
  POTENTIAL // Tiềm năng
  CONTACTED // Đã liên hệ
  NEGOTIATION // Thương thảo
  CONTRACT // Ký hợp đồng thành công
  LOST // Thất bại
}

model Deal {
  id          String  @id @default(cuid())
  code        String  @unique // ví dụ: DE-2025-0001
  title       String
  description String?

  stage    DealStage @default(POTENTIAL)
  amount   Float?
  currency String?

  appointmentAt DateTime? // ngày hẹn gặp / chốt
  closedAt      DateTime?

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  ownerId Int?
  owner   User? @relation("DealOwner", fields: [ownerId], references: [id])

  activities DealActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([ownerId])
  @@index([stage])
}

model DealActivity {
  id         String   @id @default(cuid())
  dealId     String
  authorId   Int
  content    String   @db.Text
  activityAt DateTime @default(now())
  createdAt  DateTime @default(now())

  deal   Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  author User @relation("DealActivityAuthor", fields: [authorId], references: [id])

  @@index([dealId])
  @@index([authorId])
  @@index([activityAt])
}
