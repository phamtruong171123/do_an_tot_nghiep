<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/141.0.0.0 Safari/537.36 Edg/141.0.0.0" version="28.2.8">
  <diagram name="Page-1" id="f7JCKA79Nvd7efOBUjZt">
    <mxGraphModel dx="2739" dy="1789" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\ntitle UC007 – Đăng nhập hệ thống CRM (xác thực bằng username)\n\nactor User as U\nparticipant \&quot;Login Page\&quot; as UI\nparticipant \&quot;AuthController\&quot; as AC\nparticipant \&quot;AuthService\&quot; as AS\nparticipant \&quot;UserService\&quot; as US\ndatabase \&quot;User DB\&quot; as DB\nparticipant \&quot;LogActionService\&quot; as LOG\n\nU -&gt; UI : Nhập username, password\\nvà nhấn \&quot;Đăng nhập\&quot;\nUI -&gt; AC : POST /login(username, password)\nAC -&gt; AS : validateLogin(username, password)\nAS -&gt; US : findByUsername(username)\nUS -&gt; DB : SELECT * FROM users WHERE username = ?\nDB --&gt; US : userRecord / null\nUS --&gt; AS : User / null\n\nalt [Không tìm thấy user]\n    AS -&gt; LOG : logAction(\&quot;login failed - user not found\&quot;)\n    AS --&gt; AC : Error: User not found\n    AC --&gt; UI : HTTP 404 Not Found\n    UI --&gt; U : Hiển thị \&quot;Không tồn tại tài khoản này\&quot;\nelse [Tìm thấy user]\n    AS -&gt; AS : verifyPassword(user.passwordHash, input)\n    AS -&gt; AS : checkStatus(user.status)\n    alt [Đăng nhập hợp lệ]\n        AS -&gt; AS : generateJWT(user_id, username, role)\n        AS -&gt; LOG : logAction(\&quot;login success\&quot;)\n        AS --&gt; AC : JWT Token\n        AC --&gt; UI : HTTP 200 OK + Token\n        UI --&gt; U : Hiển thị \&quot;Đăng nhập thành công\&quot;\n    else [Sai mật khẩu / Tài khoản bị khóa]\n        AS -&gt; LOG : logAction(\&quot;login failed - wrong password or inactive\&quot;)\n        AS --&gt; AC : Error: invalid credentials\n        AC --&gt; UI : HTTP 401 Unauthorized\n        UI --&gt; U : Hiển thị \&quot;Sai username hoặc mật khẩu\&quot;\n    end\nend\n@enduml\n&quot;,&quot;format&quot;:&quot;svg&quot;}" id="jChb4jrMq8WV_umfOVHA-1">
          <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1" parent="1">
            <mxGeometry x="-230" y="-540" width="1517" height="969" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
