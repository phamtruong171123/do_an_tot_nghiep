      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\ntitle Quy trình Tiếp nhận &amp; Xử lý tin nhắn đa kênh CRM tích hợp AI\n\n|Khách hàng|\nstart\n:Gửi tin nhắn qua Facebook / Zalo / Email;\n\n|Hệ thống CRM|\n:Nhận sự kiện webhook;\nif (Token hợp lệ?) then (Có)\n  :Chuẩn hóa dữ liệu tin nhắn;\nelse (Không)\n  :Ghi log \&quot;Webhook không hợp lệ\&quot;;\n  stop\nendif\n\n:Kiểm tra người gửi đã tồn tại?;\nif (Đã tồn tại?) then (Có)\n  :Gắn tin nhắn vào hội thoại hiện có;\nelse (Không)\n  :Tạo hồ sơ khách hàng và hội thoại mới;\nendif\n\n:Lưu tin nhắn vào cơ sở dữ liệu;\n:Hiển thị hội thoại trong Hộp thư hợp nhất;\n\n|Mô-đun AI (GPT-5)|\nfork\n:So khớp nội dung tin nhắn với cơ sở dữ liệu FAQ;\nif (Tìm thấy câu hỏi tương tự?) then (Có)\n  :Sinh gợi ý trả lời trong ≤ 3 giây;\nelse (Không)\n  :Báo cho CRM \&quot;Không có mẫu tương tự – cho phép gợi ý thủ công\&quot;;\nendif\nfork again\n|CS Agent|\n:Xem hội thoại mới;\n:Chờ gợi ý hoặc yêu cầu gợi ý thủ công;\nend fork\n\n|Hệ thống CRM|\n:Hiển thị nội dung gợi ý trong khung soạn thảo;\n\n|CS Agent|\n:Xem, chỉnh sửa và gửi phản hồi cho khách hàng;\n\n|Hệ thống CRM|\n:Gửi phản hồi qua API (Facebook/Zalo/Email);\nif (Gửi thành công?) then (Có)\n  :Cập nhật trạng thái hội thoại → Open;\nelse (Không)\n  :Ghi log \&quot;Lỗi gửi phản hồi\&quot;;\nendif\n\n:Kiểm tra cần tạo ticket?;\nif (Có) then (Có)\n  |CS Agent|\n  :Tạo hoặc cập nhật Ticket (Open → Pending → Resolved → Closed);\nendif\n\n|Hệ thống CRM|\n:Cập nhật hồ sơ khách hàng (nếu có thông tin mới);\n:Ghi toàn bộ thao tác vào log_action;\n\nstop\n@enduml\n&quot;,&quot;format&quot;:&quot;svg&quot;}" id="ghvRZVYOamLcs20sV_E0-1">
