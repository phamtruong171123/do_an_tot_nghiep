<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/141.0.0.0 Safari/537.36 Edg/141.0.0.0" version="28.2.8">
  <diagram name="Page-1" id="0fyyR1eO3_tSVxEhvsyl">
    <mxGraphModel dx="2148" dy="2767" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\ntitle UC002 - Gợi ý &amp; Tự động trả lời \n\nactor \&quot;Customer\&quot; as C\nparticipant \&quot;Channel Adapter\&quot; as CH\nparticipant \&quot;CRM Backend\&quot; as BE\ndatabase \&quot;DB\&quot; as DB\ncollections \&quot;FAQ / Template\&quot; as TMP\nparticipant \&quot;AI Service\&quot; as AI\nactor \&quot;Agent\&quot; as A\n\n== 1. Khách gửi tin ==\nC -&gt; CH: Gửi tin nhắn (Facebook/Zalo/Email)\nCH -&gt; BE: Webhook: newMessage(payload)\nBE -&gt; DB: Lưu Message + Conversation\n\n== 2. Kiểm tra trạng thái Agent ==\nBE -&gt; DB: Truy vấn trạng thái Agent phụ trách\nalt Agent ONLINE\n  BE -&gt; TMP: Tra FAQ\n  alt Có khớp FAQ\n    BE -&gt; AI: refineSuggestion(context)\n    AI --&gt; BE: Gợi ý AI\n    BE --&gt; A: Hiển thị gợi ý trong CRM UI\n  else Không khớp FAQ\n    BE -&gt; TMP: Trả Static Reply (mẫu tĩnh)\n    BE --&gt; A: Hiển thị gợi ý tĩnh\n  end\nelse Agent OFFLINE\n  BE -&gt; TMP: Tra FAQ\n  alt Có FAQ match\n    BE -&gt; AI: generateSuggestion(context)\n    AI --&gt; BE: Trả về nội dung AI Reply\n    BE -&gt; CH: Gửi tin AI Reply cho khách\n    CH --&gt; BE: OK\n  else Không có FAQ\n    BE -&gt; TMP: Lấy Static Reply mặc định (“Xin chào, hiện chưa có nhân viên trực…”)\n    TMP --&gt; BE: Nội dung Static Reply\n    BE -&gt; CH: Gửi Static Reply qua kênh\n    CH --&gt; BE: OK\n  end\n  BE -&gt; DB: Tạo Ticket state=Pending, gán Agent phụ trách\n  BE -&gt; DB: Ghi log_action “Auto-reply sent (Agent offline)”\nend\n\n== 3. Khi Agent online lại ==\nA -&gt; BE: Đăng nhập\nBE -&gt; DB: Lấy Ticket Pending\nBE --&gt; A: Hiển thị danh sách hội thoại cần xử lý\n\n@enduml\n&quot;,&quot;format&quot;:&quot;svg&quot;}" id="_4hDqlDDJMnSjGCORcvg-1">
          <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1" parent="1">
            <mxGeometry x="-630" y="-1900" width="1193" height="1142" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
